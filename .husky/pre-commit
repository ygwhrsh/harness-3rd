#!/bin/sh
# Pre-commit hook for TypeScript & ESLint checks

# ESLint with auto-fix on staged files
echo "🔍 Running ESLint..."
npx lint-staged --allow-empty

# TypeScript check
echo "📝 Running TypeScript type-check..."
npm run type-check

if [ $? -ne 0 ]; then
  echo "❌ TypeScript check failed. Commit aborted."
  exit 1
fi

echo "✅ Pre-commit checks passed!"
exit 0
