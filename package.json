{
  "name": "aria-dashboard-v3",
  "version": "1.0.0",
  "description": "Aria Banking Dashboard v3 - Growth Stage System (TypeScript)",
  "main": "ダッシュボード v3.html",
  "scripts": {
    "dev": "python3 -m http.server 8080",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build": "webpack --config webpack.config.js",
    "build:prod": "webpack --config webpack.config.js --mode production",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx --ignore-pattern '*.d.ts'",
    "lint:fix": "eslint src/ --ext .ts,.tsx --ignore-pattern '*.d.ts' --fix"
  },
  "keywords": [
    "banking",
    "dashboard",
    "aria",
    "react",
    "typescript",
    "design-system"
  ],
  "author": "Aria Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^8.30.0",
    "eslint-plugin-react": "^7.31.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "happy-dom": "^20.10.6",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^29.1.1",
    "ts-loader": "^9.5.0",
    "typescript": "^5.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
